{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nsmac.local/schemas/collab-registry.schema.json",
  "title": "Collab registry",
  "type": "object",
  "additionalProperties": true,
  "x-dc-validatorParity": {
    "createdAtRequiredCollabFields": [],
    "createdAtRequiredReviewerFields": ["reviewerMode", "reviewerOptionalPhases"],
    "createdAtRequiredVerificationFields": ["rounds", "subState", "participants"],
    "schemaRole": "reference/projection only; load-time validation is enforced by commands/collab/engine/registry.py validate_registry"
  },
  "required": ["activeCollabId", "collabs"],
  "properties": {
    "activeCollabId": {
      "type": ["string", "null"]
    },
    "revision": {
      "type": "integer",
      "minimum": 0,
      "description": "Canonical stale-write guard counter."
    },
    "eventIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Append-only registry changelog event counter."
    },
    "collabs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "slug", "title", "description", "status", "activePhase", "moderatorRole", "participants", "turnOrder", "transcriptPath", "archived"],
        "allOf": [
          {
            "if": {"required": ["createdAt", "reviewerRole"]},
            "then": {"required": ["reviewerMode", "reviewerOptionalPhases"]}
          },
          {
            "if": {"required": ["createdAt", "verification"]},
            "then": {
              "properties": {
                "verification": {
                  "required": ["rounds", "subState", "participants"]
                }
              }
            }
          }
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "slug": {"type": "string"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "createdAt": {"type": "string"},
          "status": {"enum": ["open", "closed", "archived"]},
          "activePhase": {"enum": ["Audit", "Discussion", "Conclusion", "Action Plan", "Handoff", "Completion"]},
          "moderatorRole": {"type": "string"},
          "participants": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["role", "agentId"],
              "properties": {
                "role": {"type": "string"},
                "agentId": {"type": "string"}
              }
            }
          },
          "turnOrder": {
            "type": "array",
            "items": {"type": "string"}
          },
          "reviewerRole": {"type": "string"},
          "reviewerMode": {"enum": ["last-in-convergent-phases"]},
          "reviewerOptionalPhases": {
            "type": "array",
            "items": {"enum": ["Audit", "Discussion", "Conclusion", "Action Plan", "Handoff", "Completion"]}
          },
          "transcriptPath": {
            "type": "string",
            "description": "Moderator project transcript path (records/<slug>.md). Written exclusively by the aggregate subcommand; read by the moderator only. Agents and lifecycle operations must not write here directly."
          },
          "aggregate": {
            "type": "object",
            "additionalProperties": true,
            "description": "Optional aggregate subcommand metadata. Runtime defaults derive sibling paths from transcriptPath when these fields are absent.",
            "properties": {
              "contributionStorePath": {
                "type": "string",
                "description": "Contribution-store path used as aggregate input, defaulting to records/<slug>-contributions.json."
              },
              "moderatorProjectTranscriptPath": {
                "type": "string",
                "description": "Moderator project transcript output path for the aggregate subcommand (moderator-read only). Defaults to transcriptPath. Lifecycle operations must not write to this path."
              },
              "rawTranscriptPath": {
                "type": "string",
                "description": "Raw transcript path (records/<slug>-raw.md). Written by lifecycle operations (speak, advance, reopen); read by agents and participants. The aggregate subcommand must not write here. Defaults to records/<slug>-raw.md."
              }
            }
          },
          "archived": {"type": "boolean"},
          "execution": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "status": {"type": "string"},
                "date": {"type": "string"},
                "entryId": {"type": "string"},
                "agentId": {"type": "string"},
                "validationResult": {"type": "string"},
                "validationScope": {"type": "string"},
                "touchedPaths": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "commits": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "contentDigest": {"type": "string"},
                "pathDigests": {"$ref": "#/$defs/pathDigests"}
              }
            }
          },
          "verification": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "rounds": {"type": "integer", "minimum": 0},
              "subState": {"enum": ["participant", "seal", "assessment"]},
              "participants": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "handoff": {
            "type": "object",
            "additionalProperties": true
          },
          "verificationSeal": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "observedRevision": {"type": "integer"},
              "executionEntries": {
                "type": "array",
                "items": {"type": "object", "additionalProperties": true}
              },
              "validationScopes": {
                "type": "array",
                "items": {"type": "string"}
              },
              "touchedPaths": {
                "type": "array",
                "items": {"type": "string"}
              },
              "contentDigest": {"type": "string"},
              "pathDigests": {"$ref": "#/$defs/pathDigests"},
              "sealedAt": {"type": "string"},
              "sealedBy": {"type": "string"}
            }
          }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": true
    },
    "identityMetrics": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "pathDigests": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["mode", "blob"],
        "properties": {
          "mode": {"type": "string"},
          "blob": {"type": "string"}
        }
      }
    }
  }
}
