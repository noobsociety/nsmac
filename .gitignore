# Managed-allowlist policy.
#
# The leading `*` ignores everything in this local command config directory.
# Source is opted in below. Runtime and host-produced state stays ignored by
# omission, including:
#   agents/         — local agent runtime payload; not source
#   ai-tracking/    — local agent runtime payload; not source
#   argv.json       — local invocation/runtime payload; not source
#   projects/       — local project state; not source
#   extensions/     — local extension cache/state; not source
#   ide_state.json  — local IDE state; not source
#   legacy skill caches — host-generated skill payloads; not source
#   plugins/        — local plugin cache; not source
#   skills/         — personal skill payload; not source
#   plans/          — local planning scratch; not source
#   subagents/      — local subagent state/transcripts; not source
*

# local command config source — tracked
!.gitignore
!CLAUDE.md
!AGENTS.md
!REPOSITORY.md
!README.md
!.collab.json
!.github/
!.github/**
!platform/data/**
!generated/
!generated/**
!platform/
!platform/**
!platform/templates/
!platform/templates/**
!tests/specs/
!tests/specs/**
!commands/
!commands/**
!tests/
!tests/**
